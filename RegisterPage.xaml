<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="FACE.RegisterPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             BackgroundColor="#F3F4F6">

    <ScrollView>
        <VerticalStackLayout Spacing="15" 
                            Padding="40" 
                            VerticalOptions="Center" 
                            HorizontalOptions="Center" 
                            WidthRequest="400">

            <Label Text="Registrasi Pengguna" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" 
                   TextColor="#1F2937" />

            <Entry x:Name="EntryUsername" 
                   Placeholder="Buat Username" 
                   BackgroundColor="White" 
                   TextColor="Black" />

            <Entry x:Name="EntryPassword" 
                   Placeholder="Buat Password" 
                   IsPassword="True" 
                   BackgroundColor="White" 
                   TextColor="Black" />

            <Picker x:Name="PickerRole" 
                    Title="-- Pilih Hak Akses --" 
                    BackgroundColor="White" 
                    TextColor="Black" />

            <Label Text="Ambil Foto Wajah untuk Database:" 
                   FontAttributes="Bold" 
                   TextColor="Black" 
                   Margin="0,10,0,0"/>

            <Frame HeightRequest="200" 
                   CornerRadius="8" 
                   Padding="0" 
                   BackgroundColor="LightGray" 
                   IsClippedToBounds="True">
                <Image x:Name="CameraPreview" Aspect="AspectFill" />
            </Frame>

            <Button Text="AMBIL FOTO WAJAH" 
                    BackgroundColor="#F59E0B" 
                    TextColor="White" 
                    Clicked="OnCaptureFaceClicked" />

            <Label x:Name="LabelFaceCaptureStatus"
                   Text="Belum ada wajah yang tervalidasi."
                   FontSize="12"
                   TextColor="#4B5563"
                   HorizontalTextAlignment="Center" />

            <Button Text="SIMPAN DAN DAFTARKAN" 
                    FontAttributes="Bold" 
                    BackgroundColor="#10B981" 
                    TextColor="White" 
                    CornerRadius="8" 
                    Margin="0,15,0,0" 
                    Clicked="OnRegisterClicked" />

            <Button Text="Kembali ke Login" 
                    BackgroundColor="Transparent" 
                    TextColor="#2563EB" 
                    Clicked="OnBackToLoginClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
