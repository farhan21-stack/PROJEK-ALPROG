<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FACE.FaceVerificationPage"
             Title="Verifikasi Wajah"
             BackgroundColor="#F3F4F6">

    <Grid RowDefinitions="Auto,*"
          Padding="28">

        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              Margin="0,0,0,22">

            <VerticalStackLayout Spacing="4">
                <Label Text="Verifikasi Wajah"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#1F2937" />

                <Label x:Name="LabelRole"
                       Text="Menyiapkan sesi pengguna"
                       FontSize="14"
                       TextColor="#4B5563" />
            </VerticalStackLayout>

            <Border Grid.Column="1"
                    BackgroundColor="#EAF0F6"
                    StrokeThickness="0"
                    Padding="12,8"
                    StrokeShape="RoundRectangle 18"
                    VerticalOptions="Start">
                <Label Text="LIVE"
                       FontSize="12"
                       FontAttributes="Bold"
                       TextColor="#2563EB" />
            </Border>
        </Grid>

        <Grid Grid.Row="1"
              ColumnDefinitions="1.3*,0.7*"
              ColumnSpacing="24">

            <Border Grid.Column="0"
                    BackgroundColor="White"
                    Stroke="#E5E7EB"
                    StrokeThickness="1"
                    Padding="18"
                    StrokeShape="RoundRectangle 18">

                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Pemindaian Kamera"
                                   FontSize="17"
                                   FontAttributes="Bold"
                                   TextColor="#1F2937" />

                            <Label Text="Pastikan wajah berada di tengah kamera dan pencahayaan cukup."
                                   FontSize="13"
                                   TextColor="#6B7280" />
                        </VerticalStackLayout>

                        <ActivityIndicator x:Name="ScanIndicator"
                                           Grid.Column="1"
                                           IsRunning="True"
                                           IsVisible="True"
                                           Color="#2563EB"
                                           HeightRequest="26"
                                           WidthRequest="26" />
                    </Grid>

                    <Border BackgroundColor="#0F172A"
                            StrokeThickness="0"
                            HeightRequest="340"
                            StrokeShape="RoundRectangle 14">

                        <Grid>
                            <Image x:Name="CameraPreview"
                                   Aspect="AspectFill" />

                            <Border BackgroundColor="#66000000"
                                    StrokeThickness="0"
                                    Padding="12,8"
                                    HorizontalOptions="Start"
                                    VerticalOptions="End"
                                    Margin="14"
                                    StrokeShape="RoundRectangle 12">
                                <Label x:Name="LabelSimilarity"
                                       Text="Status: menyiapkan kamera..."
                                       TextColor="White"
                                       FontSize="13" />
                            </Border>
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border Grid.Column="1"
                    BackgroundColor="White"
                    Stroke="#E5E7EB"
                    StrokeThickness="1"
                    Padding="22"
                    StrokeShape="RoundRectangle 18">

                <VerticalStackLayout Spacing="18">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Instruksi"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="#1F2937" />

                        <Label x:Name="LabelStatus"
                               Text="Kamera akan aktif otomatis. Arahkan wajah ke kamera untuk masuk ke dashboard."
                               FontSize="13"
                               TextColor="#6B7280" />
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1"
                             Color="#E5E7EB" />

                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="10">
                            <Label Text="1"
                                   FontAttributes="Bold"
                                   TextColor="#2563EB" />
                            <Label Grid.Column="1"
                                   Text="Posisikan wajah lurus ke kamera."
                                   FontSize="13"
                                   TextColor="#6B7280" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="10">
                            <Label Text="2"
                                   FontAttributes="Bold"
                                   TextColor="#2563EB" />
                            <Label Grid.Column="1"
                                   Text="Hindari cahaya terlalu gelap atau terlalu terang."
                                   FontSize="13"
                                   TextColor="#6B7280" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="10">
                            <Label Text="3"
                                   FontAttributes="Bold"
                                   TextColor="#2563EB" />
                            <Label Grid.Column="1"
                                   Text="Sistem akan masuk otomatis jika wajah cocok."
                                   FontSize="13"
                                   TextColor="#6B7280" />
                        </Grid>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="10"
                                         Margin="0,14,0,0">

                        <Button x:Name="BtnStartScan"
                                Text="Scan Ulang"
                                FontAttributes="Bold"
                                BackgroundColor="#2563EB"
                                TextColor="White"
                                CornerRadius="8"
                                Clicked="OnStartScanClicked" />

                        <Button Text="Kembali ke Login"
                                BackgroundColor="Transparent"
                                TextColor="#EF4444"
                                Clicked="OnCancelClicked" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
